int main() {
    Logica infija;

    string exp_matematica = "( 5 + 3 ) * 2";

    cout << "Exp. Matematica: [ " << exp_matematica << " ]" << endl;

    infija.RecibirNotacion(exp_matematica);

    cout << "Exp. Postfija: [ ";
    infija.resultado.print();
    cout << "]" << endl;

    cout << "resultado: " << infija.Evaluar() << endl;

    return 0;
}

    }

    cout << endl;

    if (orden == "ASC") {
        ListaLibros<Libro, CompararAsc<Libro>> biblioteca(criterio);

        Libro l1("tidehunter", "juan lopez", 52.10, 5);
        Libro l2("blood", "felipe lita", 38.50, 5);
        Libro l3("el fin", "juana andra", 61.20, 4);

        biblioteca.agregar(l1);
        biblioteca.agregar(l2);
        biblioteca.agregar(l3);

        menuBiblioteca(biblioteca, orden, criterio);
    }
    else {
        ListaLibros<Libro, CompararDesc<Libro>> biblioteca(criterio);

        Libro l1("tidehunter", "juan lopez", 52.10, 5);
        Libro l2("blood", "felipe lita", 38.50, 5);
        Libro l3("el fin", "juana andra", 61.20, 4);

        biblioteca.agregar(l1);
        biblioteca.agregar(l2);
        biblioteca.agregar(l3);

        menuBiblioteca(biblioteca, orden, criterio);
    }

    return 0;
}
